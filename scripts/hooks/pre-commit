#!/usr/bin/env bash
# Pre-commit hook: stamp src/version.h with the next build number.
# Install via: ./scripts/install-hooks
set -euo pipefail

VERSION_FILE="$(git rev-parse --show-toplevel)/src/version.h"

if git rev-parse --verify HEAD >/dev/null 2>&1; then
    BUILD=$(( $(git rev-list --count HEAD) + 1 ))
else
    BUILD=1
fi

if [[ ! -f "$VERSION_FILE" ]]; then
    echo "pre-commit: warning: $VERSION_FILE not found, skipping" >&2
    exit 0
fi

if ! grep -qE '#define FW_VERSION "[0-9]+\.[0-9]+' "$VERSION_FILE"; then
    echo "pre-commit: warning: FW_VERSION not found in $VERSION_FILE, skipping" >&2
    exit 0
fi

# Replace "MAJOR.MINOR" or "MAJOR.MINOR.OLD" with "MAJOR.MINOR.BUILD"
sed -i -E \
    "s/(#define FW_VERSION \")([0-9]+\.[0-9]+)(\.[0-9]+)?(\")/\1\2.${BUILD}\4/" \
    "$VERSION_FILE"

git add "$VERSION_FILE"

NEW_VER=$(grep -oE '"[0-9]+\.[0-9]+\.[0-9]+"' "$VERSION_FILE" | tr -d '"')
echo "pre-commit: FW_VERSION stamped to ${NEW_VER}" >&2
