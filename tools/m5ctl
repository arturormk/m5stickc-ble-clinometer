_CONF_FILE = pathlib.Path(__file__).parent.parent / ".m5ctl.conf"
_ENV_VAR   = "M5_BLE_ADDR"
_VERSION   = "1.3"


def _get_conf_path() -> pathlib.Path:
    if getattr(sys, 'frozen', False):
        local = pathlib.Path(sys.executable).parent / "m5ctl.conf"
        if local.is_file():
            return local
    else:
        project_root = pathlib.Path(__file__).resolve().parent.parent / ".m5ctl.conf"
        if project_root.is_file():
            return project_root
        tools_local = pathlib.Path(__file__).resolve().parent.parent / "m5ctl.conf"
        if tools_local.is_file():
            return tools_local
    return pathlib.Path.home() / ".m5ctl.conf"



def _load_device_entries() -> tuple[dict[str, tuple[str, str | None]], str | None]:
    """Return (entries, default_name).

    entries      — {name: (mac, annotation)} for all device.NAME keys
    default_name — value of default_device key, or None
    """
    conf_file = _get_conf_path()
    if not conf_file.is_file():
        return {}, None
    entries: dict[str, tuple[str, str | None]] = {}
    default_name: str | None = None
    for raw in conf_file.read_text(encoding="utf-8").splitlines():
        line = raw.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, _, val = line.partition("=")
        key, val = key.strip(), val.strip().split("#")[0].rstrip()
        if key.startswith("device."):
            name = key[len("device."):]
            if name:
                mac = val[:17]
                annotation = val[17:].strip() or None
                entries[name] = (mac, annotation)
        elif key == "default_device":
            default_name = val or None
    return entries, default_name


def _load_all_devices() -> dict[str, str]:
    """Return {name: mac} for all device.NAME entries in the config file."""
    entries, _ = _load_device_entries()
    return {name: mac for name, (mac, _) in entries.items()}


def _resolve_device(selector: str | None) -> str | None:
    # Priority: 1. explicit --device  2. $M5_BLE_ADDR  3. default_device  4. first conf entry
    if selector is not None:
        if len(selector) == 17 and selector.count(":") == 5:
            return selector
        devices = _load_all_devices()
        if selector in devices:
            return devices[selector]
        print(f"error: device {selector!r} not found in config.", file=sys.stderr)
        sys.exit(1)

    env = os.environ.get(_ENV_VAR)
    if env:
        return env

    entries, default_name = _load_device_entries()
    if default_name:
        devices = {name: mac for name, (mac, _) in entries.items()}
        if default_name in devices:
            return devices[default_name]
        print(f"warning: default_device {default_name!r} not found in config — ignored",
              file=sys.stderr)

    if entries:
        return next(iter(entries.values()))[0]
    return None


async def _check_reachable(
    devices: dict[str, str],
) -> dict[str, tuple[bool, int | None, str | None]]:
    """1-second scan; return {name: (reachable, rssi, ble_name)} for each device."""
    results = await BleakScanner.discover(timeout=1.0, return_adv=True)
    seen = {d.address: (adv.rssi, d.name) for d, adv in results.values()}
    return {
        name: (
            mac in seen,
            seen[mac][0] if mac in seen else None,
            seen[mac][1] if mac in seen else None,
        )
        for name, mac in devices.items()
    }


def _clr(code: str, text: str) -> str:
    return f"\033[{code}m{text}\033[0m" if sys.stdout.isatty() else text


def cmd_list() -> None:
    conf = _get_conf_path()
    entries, default_name = _load_device_entries()
    env = os.environ.get(_ENV_VAR)

    print(f"m5ctl {_VERSION}")
    print(f"Config: {conf}")
    print(f"{_ENV_VAR}: {env or '(not set)'}")

    devices = {name: mac for name, (mac, _) in entries.items()}

    # Prepend env var device if its MAC isn't already covered by a named entry.
    if env and env not in devices.values():
        devices = {f"${_ENV_VAR}": env} | devices
        entries = {f"${_ENV_VAR}": (env, None)} | entries

    if not entries:
        print("\nNo devices configured.")
        print(f"Set ${_ENV_VAR} or add entries like:  device.main = AA:BB:CC:DD:EE:FF")
        return

    reachability: dict[str, tuple[bool, int | None, str | None]] = {}

    async def go() -> None:
        nonlocal reachability
        reachability = await _check_reachable(devices)

    run(go())

    key_width = max(len(name) for name in entries)
    print()
    for name, (mac, annotation) in entries.items():
        reachable, rssi, ble_name = reachability.get(name, (False, None, None))
        status_text = "reachable  " if reachable else "unreachable"
        status = _clr("32" if reachable else "2;31", status_text)
        rssi_str = f"{rssi:4d} dBm" if rssi is not None else "    —   "
        ble_str = (ble_name or "(unknown)").ljust(20)
        ann_str = f"  {_clr('2', '| ' + annotation)}" if annotation else ""
        mark = "*" if name == default_name else " "
        print(f"{mark} {name:{key_width}}  {mac}  {status}  {rssi_str}  {ble_str}{ann_str}")


CONNECT_TIMEOUT = 10.0

CMD_UUID    = "7d91b001-8f3b-4b63-b6a4-5d1e6b7a1000"
RESP_UUID   = "7d91b002-8f3b-4b63-b6a4-5d1e6b7a1000"
STATUS_UUID = "7d91b003-8f3b-4b63-b6a4-5d1e6b7a1000"


@asynccontextmanager
async def _connect(address: str, timeout: float, retries: int = 3):
    last_exc: Exception | None = None
    for attempt in range(retries):
        client = BleakClient(address, timeout=timeout)
        try:
            if sys.platform == "win32":
                # WinRT's FromBluetoothAddressAsync fails immediately on a cache miss
                # (device not yet advertising after a previous disconnect).  Pre-scanning
                # waits up to `timeout` seconds for the device to appear, so the retry
                # loop's backoff applies to genuine scan failures rather than racing
                # against the device's re-advertising delay.
                device = await BleakScanner.find_device_by_address(address, timeout=timeout)
                if device is None:
                    raise BleakDeviceNotFoundError(
                        f"Device with address {address} was not found."
                    )
            await client.connect()
            break
        except (BleakError, TimeoutError, asyncio.CancelledError) as exc:
            last_exc = exc
            await client.disconnect()  # release WinRT/adapter resources before retry
            if attempt < retries - 1:
                await asyncio.sleep(0.3 * (attempt + 1))
    else:
        raise last_exc  # type: ignore[misc]
    try:
        yield client
    finally:
        await client.disconnect()


async def _start_notify(client, uuid: str, callback, retries: int = 3) -> None:
    if sys.platform == "win32":
        await asyncio.sleep(0.1)  # WinRT backend needs a moment after connect
    last_exc: Exception | None = None
    for attempt in range(retries):
        try:
            await client.start_notify(uuid, callback)
            return
        except OSError as exc:
            last_exc = exc
            if attempt < retries - 1:
                await asyncio.sleep(0.2 * (attempt + 1))
    raise last_exc  # type: ignore[misc]


async def send_and_receive(address: str, command: str, timeout: float) -> str:
    """Connect, send one command, wait for the notify response, disconnect."""
    loop = asyncio.get_running_loop()
    fut: "asyncio.Future[str]" = loop.create_future()

    def on_notify(_, data: bytearray) -> None:
        if not fut.done():
            fut.set_result(data.decode("utf-8", errors="replace").strip())

    async with _connect(address, CONNECT_TIMEOUT) as client:
        await _start_notify(client, RESP_UUID, on_notify)
        await client.write_gatt_char(CMD_UUID, command.encode("utf-8"), response=False)
        try:
            return await asyncio.wait_for(asyncio.shield(fut), timeout=timeout)
        except asyncio.TimeoutError:
            print(f"error: no response within {timeout}s", file=sys.stderr)
            sys.exit(1)


async def cmd_help(address: str, timeout: float, print_cmd: bool = False) -> None:
    """Send HELP and collect all response lines until the HELP sentinel."""
    lines: list[str] = []
    loop = asyncio.get_running_loop()
    done: "asyncio.Future[None]" = loop.create_future()

    def on_notify(_, data: bytearray) -> None:
        text = data.decode("utf-8", errors="replace").strip()
        lines.append(text)
        if text == "HELP" and not done.done():
            done.set_result(None)

    async with _connect(address, CONNECT_TIMEOUT) as client:
        await _start_notify(client, RESP_UUID, on_notify)
        if print_cmd:
            print(">>> HELP", file=sys.stderr)
        await client.write_gatt_char(CMD_UUID, b"HELP", response=False)
        try:
            await asyncio.wait_for(asyncio.shield(done), timeout=timeout)
        except asyncio.TimeoutError:
            print(f"error: no response within {timeout}s", file=sys.stderr)
            sys.exit(1)
    for line in lines:
        print(line)


async def cmd_exec(address: str, lines: list[str], timeout: float, print_cmd: bool) -> None:
    """Send a list of BLE commands sequentially over a single connection."""
    queue: "asyncio.Queue[str]" = asyncio.Queue()

    def on_notify(_, data: bytearray) -> None:
        queue.put_nowait(data.decode("utf-8", errors="replace").strip())

    async with _connect(address, CONNECT_TIMEOUT) as client:
        await _start_notify(client, RESP_UUID, on_notify)
        for line in lines:
            if print_cmd:
                print(f">>> {line}", file=sys.stderr)
            await client.write_gatt_char(CMD_UUID, line.encode("utf-8"), response=False)
            try:
                resp = await asyncio.wait_for(queue.get(), timeout=timeout)
                print(resp)
            except asyncio.TimeoutError:
                print(f"error: no response for '{line}' within {timeout}s", file=sys.stderr)
                sys.exit(1)


async def _exec_expect(
    prefix: str,
    queue: "asyncio.Queue[str]",
    timeout: float,
) -> bool:
    """Drain the notification queue until a message matching prefix arrives.

    Returns True if matched, False if the timeout expired first.
    """
    while True:
        try:
            evt = await asyncio.wait_for(queue.get(), timeout=timeout)
        except asyncio.TimeoutError:
            return False
        print(evt)
        if evt.startswith(prefix):
            return True


async def _exec_wait_tilt(
    degrees: float,
    client,
    queue: "asyncio.Queue[str]",
    per_read_timeout: float,
    total_deadline: float,
    print_cmd: bool,
) -> bool:
    """Poll GET_TILT until the delta from baseline reaches degrees, or the deadline passes.

    per_read_timeout caps each individual BLE read.
    total_deadline is an asyncio event-loop timestamp (float('inf') = no cap).
    Returns True if the tilt threshold was reached, False if the deadline expired.
    """
    if print_cmd:
        print(">>> GET_TILT (baseline)", file=sys.stderr)
    await client.write_gatt_char(CMD_UUID, b"GET_TILT", response=False)
    try:
        resp = await asyncio.wait_for(queue.get(), timeout=per_read_timeout)
    except asyncio.TimeoutError:
        return False
    print(resp)
    try:
        parts = resp.split()
        pitch0, roll0 = float(parts[1]), float(parts[2])
    except (IndexError, ValueError):
        print(f"error: unexpected tilt response: {resp!r}", file=sys.stderr)
        sys.exit(1)
    loop = asyncio.get_event_loop()
    while True:
        await asyncio.sleep(0.2)
        remaining = total_deadline - loop.time()
        if remaining <= 0:
            return False
        await client.write_gatt_char(CMD_UUID, b"GET_TILT", response=False)
        try:
            resp = await asyncio.wait_for(queue.get(), timeout=min(per_read_timeout, remaining))
        except asyncio.TimeoutError:
            return False
        try:
            parts = resp.split()
            if parts[0] != "TILT":
                continue
            pitch, roll = float(parts[1]), float(parts[2])
        except (IndexError, ValueError):
            continue
        if max(abs(pitch - pitch0), abs(roll - roll0)) >= degrees:
            print(resp)
            return True


async def cmd_run(
    address: str,
    items: list,
    timeout: float,
    print_cmd: bool,
    flags: frozenset[str] = frozenset(),
) -> None:
    """Execute a flat list of BLE commands and directives over a single connection."""
    queue: "asyncio.Queue[str]" = asyncio.Queue()

    def on_notify(_, data: bytearray) -> None:
        queue.put_nowait(data.decode("utf-8", errors="replace").strip())

    async with _connect(address, CONNECT_TIMEOUT) as client:
        await _start_notify(client, RESP_UUID, on_notify)
        flags_mutable: set[str] = set(flags)
        skip: bool = False
        skip_level: int = 0    # nesting depth at which the current skip began
        current_depth: int = 0  # current if-nesting depth
        for idx, item in enumerate(items):
            if isinstance(item, (_IfVar, _Else, _EndIf)):
                if isinstance(item, _IfVar):
                    current_depth += 1
                    if not skip:
                        is_set = item.name in flags_mutable
                        if is_set == item.negated:  # condition false → skip block
                            skip = True
                            skip_level = current_depth
                elif isinstance(item, _Else):
                    if skip and skip_level == current_depth:
                        skip = False  # our own else: un-skip
                    elif not skip:
                        skip = True   # entering the else branch: skip it
                        skip_level = current_depth
                else:  # _EndIf
                    if skip and skip_level == current_depth:
                        skip = False  # leaving the block that started the skip
                    current_depth -= 1
                continue
            if skip:
                continue
            if isinstance(item, _Wait):
                await asyncio.sleep(item.seconds)
            elif isinstance(item, _AtTime):
                now = datetime.now()
                target = now.replace(
                    hour=item.hour, minute=item.minute, second=item.second, microsecond=0
                )
                if target <= now:
                    target += timedelta(days=1)
                delta = (target - now).total_seconds()
                if delta > 0:
                    await asyncio.sleep(delta)
            elif isinstance(item, _Echo):
                print(item.text)
            elif isinstance(item, _SetVar):
                flags_mutable.add(item.name)
            elif isinstance(item, _WaitTilt):
                matched = await _exec_wait_tilt(
                    item.degrees, client, queue, timeout, float("inf"), print_cmd
                )
                if not matched:
                    print(f"error: wait_tilt timed out after {timeout}s", file=sys.stderr)
                    sys.exit(1)
            elif isinstance(item, _Expect):
                matched = await _exec_expect(item.prefix, queue, timeout)
                if not matched:
                    print(
                        f"error: line {item.lineno}: '! expect {item.prefix}' timed out after {timeout}s",
                        file=sys.stderr,
                    )
                    sys.exit(1)
            elif isinstance(item, _Timeout):
                loop = asyncio.get_event_loop()
                deadline = loop.time() + item.max_wait
                if isinstance(item.item, _Expect):
                    matched = await _exec_expect(item.item.prefix, queue, item.max_wait)
                else:  # _WaitTilt
                    matched = await _exec_wait_tilt(
                        item.item.degrees, client, queue, timeout, deadline, print_cmd
                    )
                if matched:
                    flags_mutable.discard("timedout")
                else:
                    flags_mutable.add("timedout")
            elif isinstance(item, _Exit):
                break
            else:
                if print_cmd:
                    print(f">>> {item}", file=sys.stderr)
                await client.write_gatt_char(CMD_UUID, item.encode("utf-8"), response=False)
                next_item = items[idx + 1] if idx + 1 < len(items) else None
                if not isinstance(next_item, _Expect):
                    try:
                        resp = await asyncio.wait_for(queue.get(), timeout=timeout)
                        print(resp)
                    except asyncio.TimeoutError:
                        print(f"error: no response for '{item}' within {timeout}s", file=sys.stderr)
                        sys.exit(1)


async def cmd_listen(address: str, stream_ms: int | None = None) -> None:
    """Subscribe to the response characteristic and print every notification."""

    def on_notify(_, data: bytearray) -> None:
        print(data.decode("utf-8", errors="replace").strip(), flush=True)

    print(f"Listening on {address} — Ctrl+C to stop", file=sys.stderr)
    async with _connect(address, CONNECT_TIMEOUT) as client:
        await _start_notify(client, RESP_UUID, on_notify)
        if stream_ms is not None:
            period = max(100, stream_ms)
            await client.write_gatt_char(
                CMD_UUID, f"START_STREAM {period}".encode(), response=False)
        try:
            await asyncio.Future()  # run until cancelled
        except asyncio.CancelledError:
            pass


async def cmd_terminal(address: str, timeout: float) -> None:
    """Interactive BLE terminal: persistent connection, send commands, see all notifications."""
    _readline = None
    try:
        import readline as _readline
        history = pathlib.Path.home() / ".m5ctl_history"
        with suppress(OSError):
            _readline.read_history_file(history)
        _readline.set_history_length(500)
    except ImportError:
        pass

    queue: "asyncio.Queue[str]" = asyncio.Queue()
    loop = asyncio.get_running_loop()
    prompt_showing = False
    use_ansi = sys.stdout.isatty()

    def on_notify(_, data: bytearray) -> None:
        queue.put_nowait(data.decode("utf-8", errors="replace").strip())

    async with _connect(address, CONNECT_TIMEOUT) as client:
        await _start_notify(client, RESP_UUID, on_notify)
        print(f"Connected to {address} — type commands, Ctrl+D or exit to quit.", file=sys.stderr)

        async def notify_printer() -> None:
            while True:
                msg = await queue.get()
                if prompt_showing and use_ansi:
                    sys.stdout.write(f"\r\033[K{msg}\nm5> ")
                    sys.stdout.flush()
                else:
                    print(msg, flush=True)

        printer = asyncio.create_task(notify_printer())
        try:
            while True:
                if use_ansi:
                    sys.stdout.write("m5> ")
                    sys.stdout.flush()
                prompt_showing = True
                try:
                    line = await loop.run_in_executor(None, input, "" if use_ansi else "m5> ")
                except EOFError:
                    prompt_showing = False
                    print(file=sys.stderr)
                    break
                prompt_showing = False
                line = line.strip()
                if not line:
                    continue
                if line in ("exit", "quit"):
                    break
                if line == "version":
                    print(f"m5ctl {_VERSION}")
                    continue
                ble_cmd = _terminal_line_to_ble(line, address, timeout)
                if ble_cmd is None:
                    continue
                print(f">>> {ble_cmd}", file=sys.stderr)
                await client.write_gatt_char(CMD_UUID, ble_cmd.encode("utf-8"), response=False)
        finally:
            printer.cancel()
            with suppress(asyncio.CancelledError):
                await printer

    if _readline is not None:
        with suppress(OSError):
            _readline.write_history_file(pathlib.Path.home() / ".m5ctl_history")


async def cmd_scan(timeout: float) -> None:
    """Discover nearby BLE peripherals."""
    print(f"Scanning for {timeout:g} seconds…", file=sys.stderr)
    results = await BleakScanner.discover(timeout=timeout, return_adv=True)
    if not results:
        print("No devices found.")
        return

    known = {mac: name for name, mac in _load_all_devices().items()}

    pairs = sorted(results.values(), key=lambda x: x[1].rssi or -999, reverse=True)
    for d, adv in pairs:
        name = d.name or "(unknown)"
        rssi = adv.rssi or -999
        tag = f"  {_clr('33;1', f'[{known[d.address]}]')}" if d.address in known else ""
        print(f"  {d.address}  {rssi:4d} dBm  {name}{tag}")


def run(coro) -> None:
    try:
        asyncio.run(coro)
    except (BleakError, TimeoutError, asyncio.CancelledError) as exc:
        print(f"BLE error: {exc}", file=sys.stderr)
        sys.exit(1)
    except KeyboardInterrupt:
        pass


_script_commands: list[str] | None = None


# ---------------------------------------------------------------------------
# Run-script directive types
# ---------------------------------------------------------------------------

class _Wait(NamedTuple):
    seconds: float


class _AtTime(NamedTuple):
    hour: int
    minute: int
    second: int


class _Echo(NamedTuple):
    text: str


class _WaitTilt(NamedTuple):
    degrees: float  # delta threshold in degrees (>= triggers)


class _Exit(NamedTuple):
    pass


class _Expect(NamedTuple):
    prefix: str   # wait for a notification that starts with this text
    lineno: int   # source line number, for error reporting


class _Timeout(NamedTuple):
    max_wait: float   # wall-clock cap in seconds
    item: object      # _Expect | _WaitTilt — the wrapped directive


class _IfVar(NamedTuple):
    name: str       # flag identifier, e.g. "timedout" or "noninteractive"
    negated: bool   # True for ! if_not, False for ! if
    lineno: int


class _SetVar(NamedTuple):
    name: str


class _Else(NamedTuple):
    lineno: int


class _EndIf(NamedTuple):
    lineno: int


def do_send(args, command: str) -> None:
    global _script_commands
    if _script_commands is not None:
        if args.print_cmd:
            print(f">>> {command}", file=sys.stderr)
        _script_commands.append(command)
        return
    async def go():
        if args.print_cmd:
            print(f">>> {command}", file=sys.stderr)
        resp = await send_and_receive(args.device, command, args.timeout)
        print(resp)
    run(go())


def _fmt_offset(utcoffset) -> str:
    """Format a UTC offset timedelta as +HH:MM or Z."""
    if utcoffset is None or int(utcoffset.total_seconds()) == 0:
        return "Z"
    s = int(utcoffset.total_seconds())
    sign = "+" if s >= 0 else "-"
    h, m = divmod(abs(s) // 60, 60)
    return f"{sign}{h:02d}:{m:02d}"


_TZ_ABBREVS: dict[str, str] = {
    "UTC":  "UTC",    "GMT":  "GMT",
    "CET":  "Europe/Paris",    "CEST": "Europe/Paris",
    "WET":  "Europe/Lisbon",   "WEST": "Europe/Lisbon",
    "EET":  "Europe/Helsinki", "EEST": "Europe/Helsinki",
    "EST":  "America/New_York","EDT":  "America/New_York",
    "CST":  "America/Chicago", "CDT":  "America/Chicago",
    "MST":  "America/Denver",  "MDT":  "America/Denver",
    "PST":  "America/Los_Angeles", "PDT": "America/Los_Angeles",
    "IST":  "Asia/Kolkata",   "JST":  "Asia/Tokyo",
    "AEST": "Australia/Sydney","AEDT": "Australia/Sydney",
}

# Conventional fixed offsets for common abbreviations (seconds east of UTC).
# Kept separate from _TZ_ABBREVS so that e.g. "CET" always maps to +01:00
# rather than to Europe/Paris's DST-current offset (+02:00 in summer).
_TZ_FIXED_OFFSETS: dict[str, int] = {
    "GMT":  0,       "WET":  0,       "BST":   3600,
    "CET":  3600,    "CEST": 7200,
    "EET":  7200,    "EEST": 10800,
    "EST": -18000,   "EDT": -14400,
    "CST": -21600,   "CDT": -18000,
    "MST": -25200,   "MDT": -21600,
    "PST": -28800,   "PDT": -25200,
    "IST":  19800,   "JST":  32400,
    "AEST": 36000,   "AEDT": 39600,
}


def _resolve_tz(name: str) -> ZoneInfo:
    try:
        return ZoneInfo(name)
    except (ZoneInfoNotFoundError, KeyError):
        pass
    iana = _TZ_ABBREVS.get(name.upper())
    if iana:
        return ZoneInfo(iana)
    raise SystemExit(
        f"Unknown timezone: {name!r}. "
        "Use an IANA name (e.g. Europe/Madrid) or a known abbreviation (CET, CEST, EST…)"
    )


def _tz_to_offset_str(name: str) -> str:
    """Resolve a TZ abbreviation or IANA name to a firmware-compatible +HH:MM/-HH:MM string."""
    secs = _TZ_FIXED_OFFSETS.get(name.upper())
    if secs is None:
        tz = _resolve_tz(name)
        secs = int(datetime.now(tz).utcoffset().total_seconds())
    sign = "+" if secs >= 0 else "-"
    h, m = divmod(abs(secs) // 60, 60)
    return f"{sign}{h:02d}:{m:02d}"


def _preprocess_argv(argv: list[str]) -> list[str]:
    # argparse treats tokens starting with '-' as flags.
    # For set-timezone: rewrite -HH:MM → ~HH:MM; handler converts back.
    # For set-pitchroll: rewrite -X,-Y (etc.) → ~X,-Y when the axes arg starts with '-'.
    # For set-radec: rewrite negative DEC (e.g. -16:42:58) → ~16:42:58; handler converts back.
    argv = list(argv)
    try:
        i = argv.index("set-timezone")
        if i + 1 < len(argv) and re.fullmatch(r'-\d\d:\d\d', argv[i + 1]):
            argv[i + 1] = '~' + argv[i + 1][1:]
    except ValueError:
        pass
    try:
        i = argv.index("set-pitchroll")
        # Rewrite -X or -Y (leading negative axis) to ~X / ~Y so argparse does not
        # mistake it for an option flag. Only matches actual axis specs, not -h/--help.
        if i + 1 < len(argv) and re.fullmatch(r'-[XYxy](,[+\-~XYxy]+)?', argv[i + 1]):
            argv[i + 1] = '~' + argv[i + 1][1:]
    except ValueError:
        pass
    try:
        i = argv.index("set-radec")
        if i + 2 < len(argv) and argv[i + 2].startswith("-"):
            argv[i + 2] = '~' + argv[i + 2][1:]
    except ValueError:
        pass
    return argv


