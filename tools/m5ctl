_NON_SCRIPT_CMDS = frozenset({
    "list", "version", "help", "scan", "listen",
    "exec", "script", "run", "terminal", "term", None,
})


def _terminal_line_to_ble(line: str, address: str, timeout: float) -> str | None:
    """Convert a terminal input line to a BLE command string, or None for local-only commands.

    Tries to parse as an m5ctl sub-command first; falls back to sending the raw string.
    Argparse stderr is suppressed so that raw BLE strings (e.g. GET_TILT) don't produce
    spurious error output before the raw fallback path is taken.
    """
    if line == "?":
        return "HELP"

    buf = io.StringIO()
    old_err, sys.stderr = sys.stderr, buf
    try:
        ns = parser.parse_args(_preprocess_argv(line.split()))
    except SystemExit:
        return line  # parse failed → treat as raw BLE command
    finally:
        sys.stderr = old_err

    if ns.cmd == "help":
        return "HELP"
    if ns.cmd == "listen":
        print("(already connected and listening — notifications appear above)", file=sys.stderr)
        return None
    if ns.cmd in _NON_SCRIPT_CMDS:
        print(f"('{ns.cmd}' not available in terminal; run from the command line)", file=sys.stderr)
        return None
    if ns.cmd is None:
        return line

    ns.device = address
    ns.timeout = timeout
    ns.print_cmd = False
    return _dispatch_to_ble_string(ns) or line


def cmd_script(script_args, lines: list[tuple[int, str]]) -> None:
    global _script_commands
    _script_commands = []
    for lineno, line in lines:
        line_argv = _preprocess_argv(line.split())
        try:
            line_args = parser.parse_args(line_argv)
        except SystemExit:
            print(f"error: script line {lineno}: bad command: {line!r}", file=sys.stderr)
            sys.exit(1)
        if line_args.cmd in _NON_SCRIPT_CMDS:
            print(
                f"warning: script line {lineno}: '{line_args.cmd}' cannot be batched, skipping: {line!r}",
                file=sys.stderr,
            )
            continue
        line_args.device = script_args.device
        line_args.timeout = script_args.timeout
        line_args.print_cmd = script_args.print_cmd
        dispatch(line_args)
    commands = list(_script_commands)
    _script_commands = None
    run(cmd_exec(script_args.device, commands, script_args.timeout, script_args.print_cmd))


def _dispatch_to_ble_string(line_args) -> str | None:
    """Return the BLE command string that dispatch() would send, without sending it."""
    global _script_commands
    old = _script_commands
    _script_commands = []
    dispatch(line_args)
    cmds = list(_script_commands)
    _script_commands = old
    return cmds[0] if cmds else None


def _expand_run_script(
    source: list[tuple[int, str]],
    script_args,
    *,
    _start: int = 0,
    _end: int | None = None,
) -> list:
    """Expand a source line list into a flat list of BLE strings and directive objects.

    Handles ! directives (wait, at, echo, for/endfor) and resolves loops eagerly.
    """
    result = []
    i = _start
    end = len(source) if _end is None else _end
    if_depth = 0
    seen_else_depths: set[int] = set()

    while i < end:
        lineno, line = source[i]

        if line.startswith("!"):
            tokens = line[1:].split(None, 1)
            directive = tokens[0].lower() if tokens else ""
            rest = tokens[1].split("#")[0].rstrip() if len(tokens) > 1 else ""

            if directive == "wait":
                try:
                    result.append(_Wait(float(rest)))
                except ValueError:
                    print(f"error: line {lineno}: '! wait' expects a number, got {rest!r}", file=sys.stderr)
                    sys.exit(1)
                i += 1

            elif directive == "at":
                try:
                    parts = rest.split(":")
                    if len(parts) != 3:
                        raise ValueError
                    h, m, s = int(parts[0]), int(parts[1]), int(parts[2])
                except ValueError:
                    print(f"error: line {lineno}: '! at' expects HH:MM:SS, got {rest!r}", file=sys.stderr)
                    sys.exit(1)
                result.append(_AtTime(h, m, s))
                i += 1

            elif directive == "echo":
                result.append(_Echo(rest))
                i += 1

            elif directive == "for":
                try:
                    count = int(rest)
                    if count < 0:
                        raise ValueError
                except ValueError:
                    print(f"error: line {lineno}: '! for' expects a non-negative integer, got {rest!r}", file=sys.stderr)
                    sys.exit(1)
                body_start = i + 1
                depth = 1
                j = body_start
                while j < end and depth > 0:
                    _, jline = source[j]
                    if jline.startswith("!"):
                        jtoks = jline[1:].split(None, 1)
                        jdir = jtoks[0].lower() if jtoks else ""
                        if jdir == "for":
                            depth += 1
                        elif jdir == "endfor":
                            depth -= 1
                    j += 1
                if depth != 0:
                    print(f"error: line {lineno}: '! for' has no matching '! endfor'", file=sys.stderr)
                    sys.exit(1)
                body_end = j - 1  # index of the endfor line
                body = _expand_run_script(source, script_args, _start=body_start, _end=body_end)
                for _ in range(count):
                    result.extend(body)
                i = j  # resume after endfor

            elif directive == "endfor":
                print(f"error: line {lineno}: '! endfor' without matching '! for'", file=sys.stderr)
                sys.exit(1)

            elif directive == "exit":
                result.append(_Exit())
                i += 1

            elif directive == "expect":
                if not rest:
                    print(f"error: line {lineno}: '! expect' requires a prefix", file=sys.stderr)
                    sys.exit(1)
                result.append(_Expect(rest, lineno))
                i += 1

            elif directive == "wait_tilt":
                degrees = 15.0
                if rest:
                    try:
                        degrees = float(rest)
                        if degrees <= 0:
                            raise ValueError
                    except ValueError:
                        print(f"error: line {lineno}: '! wait_tilt' expects a positive number, got {rest!r}", file=sys.stderr)
                        sys.exit(1)
                result.append(_WaitTilt(degrees))
                i += 1

            elif directive == "timeout":
                parts = rest.split(None, 2)
                if len(parts) < 2:
                    print(f"error: line {lineno}: '! timeout' expects <seconds> <directive> [args]", file=sys.stderr)
                    sys.exit(1)
                try:
                    max_wait = float(parts[0])
                    if max_wait <= 0:
                        raise ValueError
                except ValueError:
                    print(f"error: line {lineno}: '! timeout' expects a positive number, got {parts[0]!r}", file=sys.stderr)
                    sys.exit(1)
                inner_dir = parts[1].lower()
                inner_rest = parts[2] if len(parts) > 2 else ""
                if inner_dir == "expect":
                    if not inner_rest:
                        print(f"error: line {lineno}: '! timeout ... expect' requires a prefix", file=sys.stderr)
                        sys.exit(1)
                    inner_item = _Expect(inner_rest, lineno)
                elif inner_dir == "wait_tilt":
                    inner_degrees = 15.0
                    if inner_rest:
                        try:
                            inner_degrees = float(inner_rest)
                            if inner_degrees <= 0:
                                raise ValueError
                        except ValueError:
                            print(f"error: line {lineno}: '! timeout ... wait_tilt' expects a positive number, got {inner_rest!r}", file=sys.stderr)
                            sys.exit(1)
                    inner_item = _WaitTilt(inner_degrees)
                else:
                    print(f"error: line {lineno}: '! timeout' does not support '! {inner_dir}'", file=sys.stderr)
                    sys.exit(1)
                result.append(_Timeout(max_wait, inner_item))
                i += 1

            elif directive in ("if", "if_not"):
                name = rest.strip()
                if not re.fullmatch(r'[a-zA-Z_][a-zA-Z0-9_]*', name):
                    print(f"error: line {lineno}: '! {directive}' requires a valid identifier, got {name!r}", file=sys.stderr)
                    sys.exit(1)
                if_depth += 1
                result.append(_IfVar(name, negated=(directive == "if_not"), lineno=lineno))
                i += 1

            elif directive == "set":
                name = rest.strip()
                if not re.fullmatch(r'[a-zA-Z_][a-zA-Z0-9_]*', name):
                    print(f"error: line {lineno}: '! set' requires a valid identifier, got {name!r}", file=sys.stderr)
                    sys.exit(1)
                result.append(_SetVar(name))
                i += 1

            elif directive == "else":
                if if_depth == 0:
                    print(f"error: line {lineno}: '! else' without matching '! if' or '! if_not'", file=sys.stderr)
                    sys.exit(1)
                if if_depth in seen_else_depths:
                    print(f"error: line {lineno}: duplicate '! else' in '! if' block", file=sys.stderr)
                    sys.exit(1)
                seen_else_depths.add(if_depth)
                result.append(_Else(lineno))
                i += 1

            elif directive == "endif":
                if if_depth == 0:
                    print(f"error: line {lineno}: '! endif' without matching '! if' or '! if_not'", file=sys.stderr)
                    sys.exit(1)
                seen_else_depths.discard(if_depth)
                if_depth -= 1
                result.append(_EndIf(lineno))
                i += 1

            else:
                print(f"error: line {lineno}: unknown directive '! {directive}'", file=sys.stderr)
                sys.exit(1)

        else:
            line_argv = _preprocess_argv(line.split())
            try:
                line_args = parser.parse_args(line_argv)
            except SystemExit:
                print(f"error: line {lineno}: bad command: {line!r}", file=sys.stderr)
                sys.exit(1)
            if line_args.cmd in _NON_SCRIPT_CMDS:
                print(
                    f"warning: line {lineno}: '{line_args.cmd}' cannot be run, skipping: {line!r}",
                    file=sys.stderr,
                )
                i += 1
                continue
            line_args.device = script_args.device
            line_args.timeout = script_args.timeout
            line_args.print_cmd = False  # cmd_run handles print_cmd itself
            ble_cmd = _dispatch_to_ble_string(line_args)
            if ble_cmd is not None:
                result.append(ble_cmd)
            i += 1

    if if_depth != 0:
        for item in reversed(result):
            if isinstance(item, _IfVar):
                directive = "if_not" if item.negated else "if"
                print(f"error: line {item.lineno}: '! {directive} {item.name}' has no matching '! endif'", file=sys.stderr)
                break
        sys.exit(1)

    return result


# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

def dispatch(args) -> None:
    match args.cmd:
        case "help":
            run(cmd_help(args.device, args.timeout, print_cmd=args.print_cmd))
        case "ping":
            do_send(args, "PING")
        case "tilt":
            do_send(args, "GET_TILT")
        case "calibrate":
            if args.ref:
                if len(args.ref) != 3:
                    print("error: calibrate expects 0 or 3 floats (gx gy gz)", file=sys.stderr)
                    sys.exit(1)
                do_send(args, f"CALIBRATE {args.ref[0]} {args.ref[1]} {args.ref[2]}")
            else:
                do_send(args, "CALIBRATE")
        case "calibrate-reset":
            do_send(args, "CALIBRATE_RESET")
        case "status":
            do_send(args, "GET_STATUS")
        case "get-board":
            do_send(args, "GET_BOARD")
        case "get-time":
            do_send(args, "GET_TIME")
        case "get-radec":
            do_send(args, "GET_RADEC")
        case "get-altaz":
            do_send(args, "GET_ALTAZ")
        case "get-msg":
            do_send(args, "GET_MSG")
        case "cancel-msg":
            do_send(args, "CANCEL_MSG")
        case "stop-stream":
            do_send(args, "STOP_STREAM")
        case "set-time":
            cmd = f"SET_TIME {args.time}"
            if args.tz:
                cmd += f" {args.tz}"
            do_send(args, cmd)
        case "set-time-now":
            latency = timedelta(seconds=args.offset)
            if args.utc:
                now = datetime.now(timezone.utc) + latency
            elif args.timezone:
                tz = _resolve_tz(args.timezone)
                now = datetime.now(tz) + latency
            else:
                now = datetime.now().astimezone() + latency
            # Embed the UTC offset in the ISO8601 string so device subtracts it correctly.
            # An optional label override follows the timestamp.
            ts = now.strftime("%Y-%m-%dT%H:%M:%S") + _fmt_offset(now.utcoffset())
            cmd = f"SET_TIME {ts}"
            if args.label:
                label = args.label
            elif args.timezone:
                label = args.timezone
            elif not args.utc:
                label = now.strftime("%Z")
            else:
                label = ""
            if label:
                cmd += f" {label}"
            do_send(args, cmd)
        case "set-timezone":
            spec = args.spec
            if spec.startswith("~"):
                spec = "-" + spec[1:]
            label = args.label or ""
            upper = spec.upper()
            if upper not in ("UTC", "LST", "GST") and not (len(spec) > 1 and spec[0] in "+-"):
                offset = _tz_to_offset_str(spec)
                if not label:
                    label = spec
                spec = offset
            cmd = f"SET_TIME_ZONE {spec}"
            if label:
                cmd += f" {label}"
            do_send(args, cmd)
        case "set-longitude":
            do_send(args, f"SET_LONGITUDE {args.degrees}")
        case "set-radec":
            do_send(args, f"SET_RADEC {args.ra} {args.dec.replace('~', '-')}")
        case "set-altaz":
            do_send(args, f"SET_ALTAZ {args.alt} {args.az}")
        case "show-msg":
            dur = "INF" if args.duration.lower() == "inf" else args.duration
            do_send(args, f"SHOW_MSG {dur} {' '.join(args.text)}")
        case "show-msg-wait":
            dur = "INF" if args.duration.lower() == "inf" else args.duration
            do_send(args, f"SHOW_MSG_WAIT {dur} {args.buttons} {' '.join(args.text)}")
        case "night-mode":
            do_send(args, f"SET_NIGHT_MODE {args.state.upper()}")
        case "get-pitchroll":
            do_send(args, "GET_PITCHROLL")
        case "set-pitchroll":
            axes = args.axes.replace('~', '-').upper()
            parts = axes.split(',')
            valid = {'+X', '-X', '+Y', '-Y'}
            if len(parts) != 2 or parts[0] not in valid or parts[1] not in valid:
                print(
                    f"error: axes must be PITCH,ROLL where each is one of: +X  -X  +Y  -Y\n"
                    f"  e.g.:  m5ctl set-pitchroll +X,-Y\n"
                    f"  Use ~ instead of - for negative pitch: m5ctl set-pitchroll ~X,-Y",
                    file=sys.stderr,
                )
                sys.exit(1)
            do_send(args, f"SET_PITCHROLL {parts[0]},{parts[1]}")
        case "set-screen":
            do_send(args, f"SET_SCREEN {args.name}")
        case "beep":
            cmd = "BEEP " + " ".join(args.notes) if args.notes else "BEEP"
            do_send(args, cmd)
        case "persist":
            do_send(args, "PERSIST")
        case "persist-read":
            do_send(args, "PERSIST READ")
        case "persist-clear":
            do_send(args, "PERSIST CLEAR")
        case "persist-restore":
            do_send(args, "PERSIST RESTORE")
        case "reboot":
            do_send(args, "REBOOT")
        case "exec":
            if args.file != "-" and not pathlib.Path(args.file).exists():
                print(f"error: file not found: {args.file!r}", file=sys.stderr)
                sys.exit(1)
            if args.file == "-":
                raw = sys.stdin.read().splitlines()
            else:
                raw = pathlib.Path(args.file).read_text(encoding="utf-8").splitlines()
            lines = [l.strip() for l in raw if l.strip() and not l.strip().startswith("#")]
            run(cmd_exec(args.device, lines, args.timeout, args.print_cmd))
        case "script":
            if args.file != "-" and not pathlib.Path(args.file).exists():
                print(f"error: file not found: {args.file!r}", file=sys.stderr)
                sys.exit(1)
            if args.file == "-":
                raw = sys.stdin.read().splitlines()
            else:
                raw = pathlib.Path(args.file).read_text(encoding="utf-8").splitlines()
            lines = [(i + 1, l.strip()) for i, l in enumerate(raw)
                     if l.strip() and not l.strip().startswith("#")]
            cmd_script(args, lines)
        case "run":
            if args.file != "-" and not pathlib.Path(args.file).exists():
                print(f"error: file not found: {args.file!r}", file=sys.stderr)
                sys.exit(1)
            if args.file == "-":
                raw = sys.stdin.read().splitlines()
            else:
                raw = pathlib.Path(args.file).read_text(encoding="utf-8").splitlines()
            lines = [(i + 1, l.strip()) for i, l in enumerate(raw)
                     if l.strip() and not l.strip().startswith("#")]
            items = _expand_run_script(lines, args)
            run(cmd_run(args.device, items, args.timeout, args.print_cmd,
                        flags=frozenset(args.flags or [])))
        case "listen":
            run(cmd_listen(args.device, stream_ms=args.stream))
        case "terminal" | "term":
            run(cmd_terminal(args.device, args.timeout))
        case "scan":
            run(cmd_scan(args.timeout))


def main() -> None:
    args = parser.parse_args(_preprocess_argv(sys.argv[1:]))

    if args.cmd == "version":
        print(f"m5ctl {_VERSION}")
        return

    if args.cmd == "list":
        cmd_list()
        return

    if args.cmd != "scan":
        args.device = _resolve_device(args.device)
        if not args.device:
            print(
                f"error: no device address configured.\n"
                f"  Set ${_ENV_VAR}, use --device ADDR_OR_NAME, or add\n"
                f"  'device.NAME = MAC' entries to {_CONF_FILE.name}.",
                file=sys.stderr,
            )
            sys.exit(1)

    dispatch(args)


if __name__ == "__main__":
    main()
