#!/usr/bin/env python3
"""m5ctl — command-line interface for the M5StickC NexStar clinometer."""

import asyncio
import argparse
import sys
from datetime import datetime, timezone, timedelta
from zoneinfo import ZoneInfo, ZoneInfoNotFoundError
from bleak import BleakClient, BleakScanner, BleakError

DEFAULT_ADDRESS = "F0:24:F9:9B:E2:52"
CONNECT_TIMEOUT = 10.0

CMD_UUID    = "7d91b001-8f3b-4b63-b6a4-5d1e6b7a1000"
RESP_UUID   = "7d91b002-8f3b-4b63-b6a4-5d1e6b7a1000"
STATUS_UUID = "7d91b003-8f3b-4b63-b6a4-5d1e6b7a1000"


async def send_and_receive(address: str, command: str, timeout: float) -> str:
    """Connect, send one command, wait for the notify response, disconnect."""
    loop = asyncio.get_running_loop()
    fut: "asyncio.Future[str]" = loop.create_future()

    def on_notify(_, data: bytearray) -> None:
        if not fut.done():
            fut.set_result(data.decode("utf-8", errors="replace").strip())

    async with BleakClient(address, timeout=CONNECT_TIMEOUT) as client:
        await client.start_notify(RESP_UUID, on_notify)
        await client.write_gatt_char(CMD_UUID, command.encode("utf-8"), response=False)
        try:
            return await asyncio.wait_for(asyncio.shield(fut), timeout=timeout)
        except asyncio.TimeoutError:
            print(f"error: no response within {timeout}s", file=sys.stderr)
            sys.exit(1)


async def cmd_listen(address: str) -> None:
    """Subscribe to the response characteristic and print every notification."""

    def on_notify(_, data: bytearray) -> None:
        print(data.decode("utf-8", errors="replace").strip(), flush=True)

    print(f"Listening on {address} — Ctrl+C to stop", file=sys.stderr)
    async with BleakClient(address, timeout=CONNECT_TIMEOUT) as client:
        await client.start_notify(RESP_UUID, on_notify)
        try:
            await asyncio.Future()  # run until cancelled
        except asyncio.CancelledError:
            pass


async def cmd_scan() -> None:
    """Discover nearby BLE peripherals."""
    print("Scanning for 5 seconds…", file=sys.stderr)
    devices = await BleakScanner.discover(timeout=5.0)
    if not devices:
        print("No devices found.")
        return
    for d in sorted(devices, key=lambda x: x.rssi or -999, reverse=True):
        name = d.name or "(unknown)"
        print(f"  {d.address}  {d.rssi:4d} dBm  {name}")


def run(coro) -> None:
    try:
        asyncio.run(coro)
    except BleakError as exc:
        print(f"BLE error: {exc}", file=sys.stderr)
        sys.exit(1)
    except KeyboardInterrupt:
        pass


def do_send(args, command: str) -> None:
    async def go():
        resp = await send_and_receive(args.device, command, args.timeout)
        print(resp)
    run(go())


def _compute_lst(utc_unix: float, longitude_deg: float, dut1: float = 0.0) -> int:
    """Returns current Local Sidereal Time as integer seconds [0, 86400)."""
    ut1 = utc_unix + dut1
    jd  = ut1 / 86400.0 + 2440587.5
    d   = jd - 2451545.0
    T   = d / 36525.0
    gmst_deg = (280.46061837
                + 360.98564736629 * d
                + 0.000387933 * T**2
                - T**3 / 38710000.0) % 360.0
    lst_deg  = (gmst_deg + longitude_deg) % 360.0
    return int(lst_deg * 240.0) % 86400


_TZ_ABBREVS: dict[str, str] = {
    "UTC":  "UTC",    "GMT":  "GMT",
    "CET":  "Europe/Paris",    "CEST": "Europe/Paris",
    "WET":  "Europe/Lisbon",   "WEST": "Europe/Lisbon",
    "EET":  "Europe/Helsinki", "EEST": "Europe/Helsinki",
    "EST":  "America/New_York","EDT":  "America/New_York",
    "CST":  "America/Chicago", "CDT":  "America/Chicago",
    "MST":  "America/Denver",  "MDT":  "America/Denver",
    "PST":  "America/Los_Angeles", "PDT": "America/Los_Angeles",
    "IST":  "Asia/Kolkata",   "JST":  "Asia/Tokyo",
    "AEST": "Australia/Sydney","AEDT": "Australia/Sydney",
}


def _resolve_tz(name: str) -> ZoneInfo:
    try:
        return ZoneInfo(name)
    except (ZoneInfoNotFoundError, KeyError):
        pass
    iana = _TZ_ABBREVS.get(name.upper())
    if iana:
        return ZoneInfo(iana)
    raise SystemExit(
        f"Unknown timezone: {name!r}. "
        "Use an IANA name (e.g. Europe/Madrid) or a known abbreviation (CET, CEST, EST…)"
    )


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="m5ctl",
        description="Control the M5StickC NexStar clinometer over BLE.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
examples:
  m5ctl tilt
  m5ctl status
  m5ctl set-time-now                    # local time (default)
  m5ctl set-time-now --utc             # UTC
  m5ctl set-time-now --timezone CEST   # named timezone
  m5ctl set-time-now --timezone Europe/Madrid
  m5ctl set-time "2026-05-14T12:30:00+01:00"
  m5ctl set-radec "12:34:56" "+07:08:09"
  m5ctl set-altaz "+43.2" "181.7"
  m5ctl show-msg 5 "Moving altitude axis"
  m5ctl show-msg inf "Waiting for user"
  m5ctl show-msg-wait 30 M5 "Press M5 when ready"
  m5ctl cancel-msg
  m5ctl stream 500         # enable streaming every 500 ms
  m5ctl night-mode on      # enable red-only night mode
  m5ctl night-mode off     # restore normal colors
  m5ctl beep               # standard attention beep (880 Hz, 200 ms)
  m5ctl beep C4 E4 G4 C'2 -4 C'8 B8 A8 G8 C2  # play a melody
  m5ctl listen             # print all notifications (use after stream)
  m5ctl scan               # discover nearby BLE devices
        """,
    )
    parser.add_argument(
        "-d", "--device",
        default=DEFAULT_ADDRESS,
        metavar="ADDR",
        help=f"BLE address (default: {DEFAULT_ADDRESS})",
    )
    parser.add_argument(
        "-t", "--timeout",
        type=float,
        default=5.0,
        metavar="SEC",
        help="seconds to wait for a response (default: 5)",
    )

    sub = parser.add_subparsers(dest="cmd", metavar="COMMAND")
    sub.required = True

    # --- simple query commands ---
    sub.add_parser("ping",        help="Ping the device")
    sub.add_parser("tilt",        help="Get current X/Y tilt angles")
    sub.add_parser("status",      help="Get device status (screen, BLE, battery, stream)")
    sub.add_parser("get-time",    help="Get current device time")
    sub.add_parser("get-radec",   help="Get stored RA/Dec values")
    sub.add_parser("get-altaz",   help="Get stored Alt/Az values")
    sub.add_parser("get-msg",     help="Get current message state")
    sub.add_parser("cancel-msg",  help="Cancel the active message immediately")
    sub.add_parser("stop-stream", help="Disable tilt streaming")
    sub.add_parser("listen",      help="Print all BLE notifications (Ctrl+C to stop)")
    sub.add_parser("scan",        help="Scan for nearby BLE devices")

    # --- parameterised commands ---
    p = sub.add_parser("set-time",
                       help="Set device clock from ISO-8601 string with optional timezone label")
    p.add_argument("time", help="e.g. 2026-05-14T12:30:00Z  or  2026-05-14T12:30:00+01:00")
    p.add_argument("tz",   nargs="?",
                   help="Optional timezone label e.g. CET, EST (use when time has no offset suffix)")

    p = sub.add_parser("set-time-now",
                       help="Set device clock to the current host time")
    grp = p.add_mutually_exclusive_group()
    grp.add_argument("--utc",      action="store_true",
                     help="Use UTC time (label: UTC)")
    grp.add_argument("--local",    action="store_true",
                     help="Use host local time (default)")
    grp.add_argument("--timezone", metavar="TZ",
                     help="Use named timezone, e.g. Europe/Madrid or CEST")
    p.add_argument("--offset", type=int, default=3, metavar="N",
                   help="Seconds added for BLE latency compensation (default: 3)")

    p = sub.add_parser("set-sidereal-now",
                       help="Set device clock to current Local Sidereal Time")
    p.add_argument("--longitude", type=float, required=True, metavar="DEG",
                   help="Observer longitude in degrees east (negative = west)")
    p.add_argument("--dut1",     type=float, default=0.0,  metavar="SEC",
                   help="DUT1 = UT1 - UTC in seconds (from IERS bulletin, default 0)")
    p.add_argument("--label",    default="LST", metavar="STR",
                   help="Label shown on device screen (default: LST)")
    p.add_argument("--offset",   type=int, default=3, metavar="N",
                   help="Seconds added for BLE latency compensation (default: 3)")

    p = sub.add_parser("set-radec", help="Set RA/Dec display values")
    p.add_argument("ra",  help="e.g. 12:34:56")
    p.add_argument("dec", help="e.g. +07:08:09")

    p = sub.add_parser("set-altaz", help="Set Alt/Az display values")
    p.add_argument("alt", help="e.g. +43.2")
    p.add_argument("az",  help="e.g. 181.7")

    p = sub.add_parser("show-msg",
                       help="Display a message (show-msg <seconds|inf> <text>)")
    p.add_argument("duration", help="Display duration in seconds, or 'inf'")
    p.add_argument("text",     help="Message text")

    p = sub.add_parser("show-msg-wait",
                       help="Display a message and watch for a button press "
                            "(show-msg-wait <seconds|inf> <buttons> <text>)")
    p.add_argument("duration", help="Display duration in seconds, or 'inf'")
    p.add_argument("buttons",  help="Button mask: M5  A  B  M5,A  ANY")
    p.add_argument("text",     help="Message text")

    p = sub.add_parser("stream",
                       help="Enable periodic tilt notifications (stream <period_ms>)")
    p.add_argument("period_ms", type=int,
                   help="Notification period in milliseconds (minimum 100)")

    p = sub.add_parser("night-mode", help="Enable or disable red-only night mode")
    p.add_argument("state", choices=["on", "off"], help="on or off")

    p = sub.add_parser("beep",
                       help="Play a beep or melody (beep [note ...])")
    p.add_argument("notes", nargs="*",
                   metavar="NOTE",
                   help="Musical notation tokens, e.g. C4 E4 G4 C'2 "
                        "(omit for a standard beep). "
                        "Octave: ' up, , down from middle C. "
                        "Duration: 1/2/4/8/16. Dot: .. Sharp: #. Flat: b. Rest: -")

    args = parser.parse_args()

    match args.cmd:
        case "ping":
            do_send(args, "PING")
        case "tilt":
            do_send(args, "GET_TILT")
        case "status":
            do_send(args, "GET_STATUS")
        case "get-time":
            do_send(args, "GET_TIME")
        case "get-radec":
            do_send(args, "GET_RADEC")
        case "get-altaz":
            do_send(args, "GET_ALTAZ")
        case "get-msg":
            do_send(args, "GET_MSG")
        case "cancel-msg":
            do_send(args, "CANCEL_MSG")
        case "stop-stream":
            do_send(args, "STOP_STREAM")
        case "set-time":
            cmd = f"SET_TIME {args.time}"
            if args.tz:
                cmd += f" {args.tz}"
            do_send(args, cmd)
        case "set-time-now":
            offset = timedelta(seconds=args.offset)
            if args.utc:
                now = datetime.now(timezone.utc) + offset
                label = "UTC"
            elif args.timezone:
                tz = _resolve_tz(args.timezone)
                now = datetime.now(tz) + offset
                label = args.timezone[:15]
            else:
                now = datetime.now().astimezone() + offset
                label = now.strftime("%Z")
            ts = now.strftime("%Y-%m-%dT%H:%M:%S")
            cmd = f"SET_TIME {ts}"
            if label:
                cmd += f" {label}"
            do_send(args, cmd)
        case "set-sidereal-now":
            utc_now = datetime.now(timezone.utc).timestamp() + args.offset
            lst_sec = _compute_lst(utc_now, args.longitude, args.dut1)
            h = lst_sec // 3600
            m = (lst_sec % 3600) // 60
            s = lst_sec % 60
            ts = f"{h:02d}:{m:02d}:{s:02d}"
            do_send(args, f"SET_SIDEREAL_TIME {ts} {args.label}")
        case "set-radec":
            do_send(args, f"SET_RADEC {args.ra} {args.dec}")
        case "set-altaz":
            do_send(args, f"SET_ALTAZ {args.alt} {args.az}")
        case "show-msg":
            dur = "INF" if args.duration.lower() == "inf" else args.duration
            do_send(args, f"SHOW_MSG {dur} {args.text}")
        case "show-msg-wait":
            dur = "INF" if args.duration.lower() == "inf" else args.duration
            do_send(args, f"SHOW_MSG_WAIT {dur} {args.buttons} {args.text}")
        case "stream":
            do_send(args, f"START_STREAM {args.period_ms}")
        case "night-mode":
            do_send(args, f"SET_NIGHT_MODE {args.state.upper()}")
        case "beep":
            cmd = "BEEP " + " ".join(args.notes) if args.notes else "BEEP"
            do_send(args, cmd)
        case "listen":
            run(cmd_listen(args.device))
        case "scan":
            run(cmd_scan())


if __name__ == "__main__":
    main()
