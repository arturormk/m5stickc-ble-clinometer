#!/usr/bin/env python3
"""m5ctl — command-line interface for the M5StickC NexStar clinometer."""

import asyncio
import argparse
import os
import pathlib
import sys
from datetime import datetime, timezone, timedelta
from zoneinfo import ZoneInfo, ZoneInfoNotFoundError
from bleak import BleakClient, BleakScanner, BleakError

_CONF_FILE = pathlib.Path(__file__).parent.parent / ".m5ctl.conf"
_ENV_VAR   = "M5_BLE_ADDR"


def _get_conf_path() -> pathlib.Path:
    if getattr(sys, 'frozen', False):
        local = pathlib.Path(sys.executable).parent / "m5ctl.conf"
        if local.is_file():
            return local
    else:
        project_root = pathlib.Path(__file__).resolve().parent.parent / ".m5ctl.conf"
        if project_root.is_file():
            return project_root
        tools_local = pathlib.Path(__file__).resolve().parent / "m5ctl.conf"
        if tools_local.is_file():
            return tools_local
    return pathlib.Path.home() / ".m5ctl.conf"


def _load_device_addr() -> str | None:
    conf_file = _get_conf_path()
    if not conf_file.is_file():
        return None
    for raw in conf_file.read_text().splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if "=" in line:
            key, _, val = line.partition("=")
            if key.strip() == "device":
                return val.strip() or None
    return None


CONNECT_TIMEOUT = 10.0

CMD_UUID    = "7d91b001-8f3b-4b63-b6a4-5d1e6b7a1000"
RESP_UUID   = "7d91b002-8f3b-4b63-b6a4-5d1e6b7a1000"
STATUS_UUID = "7d91b003-8f3b-4b63-b6a4-5d1e6b7a1000"


async def send_and_receive(address: str, command: str, timeout: float) -> str:
    """Connect, send one command, wait for the notify response, disconnect."""
    loop = asyncio.get_running_loop()
    fut: "asyncio.Future[str]" = loop.create_future()

    def on_notify(_, data: bytearray) -> None:
        if not fut.done():
            fut.set_result(data.decode("utf-8", errors="replace").strip())

    async with BleakClient(address, timeout=CONNECT_TIMEOUT) as client:
        await client.start_notify(RESP_UUID, on_notify)
        await client.write_gatt_char(CMD_UUID, command.encode("utf-8"), response=False)
        try:
            return await asyncio.wait_for(asyncio.shield(fut), timeout=timeout)
        except asyncio.TimeoutError:
            print(f"error: no response within {timeout}s", file=sys.stderr)
            sys.exit(1)


async def cmd_help(address: str, timeout: float) -> None:
    """Send HELP and collect all response lines until the OK sentinel."""
    lines: list[str] = []
    loop = asyncio.get_running_loop()
    done: "asyncio.Future[None]" = loop.create_future()

    def on_notify(_, data: bytearray) -> None:
        text = data.decode("utf-8", errors="replace").strip()
        if text == "OK":
            if not done.done():
                done.set_result(None)
        else:
            lines.append(text)

    async with BleakClient(address, timeout=CONNECT_TIMEOUT) as client:
        await client.start_notify(RESP_UUID, on_notify)
        await client.write_gatt_char(CMD_UUID, b"HELP", response=False)
        try:
            await asyncio.wait_for(asyncio.shield(done), timeout=timeout)
        except asyncio.TimeoutError:
            print(f"error: no response within {timeout}s", file=sys.stderr)
            sys.exit(1)
    for line in lines:
        print(line)


async def cmd_listen(address: str, stream_ms: int | None = None) -> None:
    """Subscribe to the response characteristic and print every notification."""

    def on_notify(_, data: bytearray) -> None:
        print(data.decode("utf-8", errors="replace").strip(), flush=True)

    print(f"Listening on {address} — Ctrl+C to stop", file=sys.stderr)
    async with BleakClient(address, timeout=CONNECT_TIMEOUT) as client:
        await client.start_notify(RESP_UUID, on_notify)
        if stream_ms is not None:
            period = max(100, stream_ms)
            await client.write_gatt_char(
                CMD_UUID, f"START_STREAM {period}".encode(), response=False)
        try:
            await asyncio.Future()  # run until cancelled
        except asyncio.CancelledError:
            pass


async def cmd_scan() -> None:
    """Discover nearby BLE peripherals."""
    print("Scanning for 5 seconds…", file=sys.stderr)
    results = await BleakScanner.discover(timeout=5.0, return_adv=True)
    if not results:
        print("No devices found.")
        return
    pairs = sorted(results.values(), key=lambda x: x[1].rssi or -999, reverse=True)
    for d, adv in pairs:
        name = d.name or "(unknown)"
        rssi = adv.rssi or -999
        print(f"  {d.address}  {rssi:4d} dBm  {name}")


def run(coro) -> None:
    try:
        asyncio.run(coro)
    except BleakError as exc:
        print(f"BLE error: {exc}", file=sys.stderr)
        sys.exit(1)
    except KeyboardInterrupt:
        pass


def do_send(args, command: str) -> None:
    async def go():
        resp = await send_and_receive(args.device, command, args.timeout)
        print(resp)
    run(go())


def _fmt_offset(utcoffset) -> str:
    """Format a UTC offset timedelta as +HH:MM or Z."""
    if utcoffset is None or int(utcoffset.total_seconds()) == 0:
        return "Z"
    s = int(utcoffset.total_seconds())
    sign = "+" if s >= 0 else "-"
    h, m = divmod(abs(s) // 60, 60)
    return f"{sign}{h:02d}:{m:02d}"


_TZ_ABBREVS: dict[str, str] = {
    "UTC":  "UTC",    "GMT":  "GMT",
    "CET":  "Europe/Paris",    "CEST": "Europe/Paris",
    "WET":  "Europe/Lisbon",   "WEST": "Europe/Lisbon",
    "EET":  "Europe/Helsinki", "EEST": "Europe/Helsinki",
    "EST":  "America/New_York","EDT":  "America/New_York",
    "CST":  "America/Chicago", "CDT":  "America/Chicago",
    "MST":  "America/Denver",  "MDT":  "America/Denver",
    "PST":  "America/Los_Angeles", "PDT": "America/Los_Angeles",
    "IST":  "Asia/Kolkata",   "JST":  "Asia/Tokyo",
    "AEST": "Australia/Sydney","AEDT": "Australia/Sydney",
}


def _resolve_tz(name: str) -> ZoneInfo:
    try:
        return ZoneInfo(name)
    except (ZoneInfoNotFoundError, KeyError):
        pass
    iana = _TZ_ABBREVS.get(name.upper())
    if iana:
        return ZoneInfo(iana)
    raise SystemExit(
        f"Unknown timezone: {name!r}. "
        "Use an IANA name (e.g. Europe/Madrid) or a known abbreviation (CET, CEST, EST…)"
    )


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="m5ctl",
        description="Control the M5StickC NexStar clinometer over BLE.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
examples:
  m5ctl tilt                # pitch, roll in degrees, gravity magnitude in g
  m5ctl calibrate                             # zero at current orientation; prints ref vector
  m5ctl calibrate +0.0023 -0.0150 +0.9999   # restore a previously saved calibration
  m5ctl calibrate-reset                       # restore hardware reference
  m5ctl status
  m5ctl set-time-now                    # sync from host clock (embeds UTC offset)
  m5ctl set-time-now --utc             # force UTC
  m5ctl set-time-now --timezone CEST   # use named timezone
  m5ctl set-time-now --timezone Europe/Madrid
  m5ctl set-time "2026-05-14T12:30:00+01:00"
  m5ctl set-timezone +09:00 JST        # switch display to JST without re-syncing
  m5ctl set-timezone LST               # switch to sidereal (needs set-longitude first)
  m5ctl set-longitude 135.5            # set observer longitude (Osaka)
  m5ctl set-radec "12:34:56" "+07:08:09"
  m5ctl set-altaz "+43.2" "181.7"
  m5ctl show-msg 5 "Moving altitude axis"
  m5ctl show-msg inf "Waiting for user"
  m5ctl show-msg-wait 30 M5 "Press M5 when ready"
  m5ctl cancel-msg
  m5ctl listen --stream 500   # stream tilt every 500 ms and print notifications
  m5ctl night-mode on      # enable red-only night mode
  m5ctl night-mode off     # restore normal colors
  m5ctl beep               # standard attention beep (880 Hz, 200 ms)
  m5ctl beep "C4 E4 G4 C'2 -4 C'8 B8 A8 G8 C2"  # play a melody
  m5ctl persist            # save current tz, longitude, calibration to NVS
  m5ctl persist-read       # show stored NVS values (valid flag + all keys)
  m5ctl persist-clear      # invalidate stored values (1 NVS write, data kept)
  m5ctl persist-restore    # re-enable and apply last stored values in-session
  m5ctl reboot             # software-reset the device
  m5ctl help               # list all accepted BLE commands
  m5ctl listen             # print all notifications (events, screen changes…)
  m5ctl scan               # discover nearby BLE devices
        """,
    )
    parser.add_argument(
        "-d", "--device",
        default=os.environ.get(_ENV_VAR) or _load_device_addr(),
        metavar="ADDR",
        help=(
            f"BLE MAC address of the device. "
            f"Priority: --device > ${_ENV_VAR} > {_CONF_FILE.name}. "
            f"Create .m5ctl.conf in the project root with: device=AA:BB:CC:DD:EE:FF"
        ),
    )
    parser.add_argument(
        "-t", "--timeout",
        type=float,
        default=5.0,
        metavar="SEC",
        help="seconds to wait for a response (default: 5)",
    )

    sub = parser.add_subparsers(dest="cmd", metavar="COMMAND")
    sub.required = True

    # --- simple query commands ---
    sub.add_parser("help",        help="List all accepted BLE commands")
    sub.add_parser("ping",        help="Ping the device")
    sub.add_parser("tilt",        help="Get current pitch/roll angles and gravity magnitude (g)")
    p = sub.add_parser("calibrate",
                       help="Calibrate from current orientation, or restore a saved reference vector")
    p.add_argument("ref", nargs="*", metavar="FLOAT",
                   help="Optional saved reference: gx gy gz from a previous CALIBRATE response")
    sub.add_parser("calibrate-reset", help="Remove calibration and restore hardware reference")
    sub.add_parser("status",      help="Get device status (screen, BLE, battery, stream)")
    sub.add_parser("get-time",    help="Get current device time")
    sub.add_parser("get-radec",   help="Get stored RA/Dec values")
    sub.add_parser("get-altaz",   help="Get stored Alt/Az values")
    sub.add_parser("get-msg",     help="Get current message state")
    sub.add_parser("cancel-msg",  help="Cancel the active message immediately")
    sub.add_parser("stop-stream", help="Disable tilt streaming")
    p = sub.add_parser("listen",   help="Print all BLE notifications (Ctrl+C to stop)")
    p.add_argument("--stream", type=int, metavar="MS",
                   help="Start tilt streaming at this period (ms) before listening")
    sub.add_parser("scan",        help="Scan for nearby BLE devices")

    # --- parameterised commands ---
    p = sub.add_parser("set-time",
                       help="Set device clock from ISO-8601 string with optional timezone label")
    p.add_argument("time", help="e.g. 2026-05-14T12:30:00Z  or  2026-05-14T12:30:00+01:00")
    p.add_argument("tz",   nargs="?",
                   help="Optional timezone label e.g. CET, EST (use when time has no offset suffix)")

    p = sub.add_parser("set-time-now",
                       help="Set device clock to the current host time")
    grp = p.add_mutually_exclusive_group()
    grp.add_argument("--utc",      action="store_true",
                     help="Use UTC time")
    grp.add_argument("--local",    action="store_true",
                     help="Use host local time (default)")
    grp.add_argument("--timezone", metavar="TZ",
                     help="Use named timezone, e.g. Europe/Madrid or CEST")
    p.add_argument("--label", default="", metavar="STR",
                   help="Override display label on device (e.g. JST)")
    p.add_argument("--offset", type=int, default=3, metavar="N",
                   help="Seconds added for BLE latency compensation (default: 3)")

    p = sub.add_parser("set-timezone",
                       help="Set display timezone/mode without changing the clock")
    p.add_argument("spec",
                   help="Offset (+HH:MM or -HH:MM), UTC, or LST/GST for sidereal")
    p.add_argument("label", nargs="?", default="",
                   help="Optional display label override (e.g. JST, CET)")

    p = sub.add_parser("set-longitude",
                       help="Set observer longitude for sidereal time computation")
    p.add_argument("degrees", type=float,
                   help="Longitude in degrees east (negative = west), range ±180")

    p = sub.add_parser("set-radec", help="Set RA/Dec display values")
    p.add_argument("ra",  help="e.g. 12:34:56")
    p.add_argument("dec", help="e.g. +07:08:09")

    p = sub.add_parser("set-altaz", help="Set Alt/Az display values")
    p.add_argument("alt", help="e.g. +43.2")
    p.add_argument("az",  help="e.g. 181.7")

    p = sub.add_parser("show-msg",
                       help="Display a message (show-msg <seconds|inf> <text>)")
    p.add_argument("duration", help="Display duration in seconds, or 'inf'")
    p.add_argument("text",     help="Message text")

    p = sub.add_parser("show-msg-wait",
                       help="Display a message and watch for a button press "
                            "(show-msg-wait <seconds|inf> <buttons> <text>)")
    p.add_argument("duration", help="Display duration in seconds, or 'inf'")
    p.add_argument("buttons",  help="Button mask: M5  A  B  M5,A  ANY")
    p.add_argument("text",     help="Message text")


    p = sub.add_parser("night-mode", help="Enable or disable red-only night mode")
    p.add_argument("state", choices=["on", "off"], help="on or off")

    sub.add_parser("persist",         help="Save current tz, timezone offset, longitude and calibration to NVS")
    sub.add_parser("persist-read",    help="Read stored NVS values (validity flag and all keys)")
    sub.add_parser("persist-clear",   help="Invalidate stored values with a single NVS write")
    sub.add_parser("persist-restore", help="Re-enable and apply last stored NVS values in-session")
    sub.add_parser("reboot",          help="Software-reset the device")

    p = sub.add_parser("beep",
                       help="Play a beep or melody (beep [note ...])")
    p.add_argument("notes", nargs="*",
                   metavar="NOTE",
                   help="Musical notation tokens, e.g. C4 E4 G4 C'2 "
                        "(omit for a standard beep). "
                        "Octave: ' up, , down from middle C. "
                        "Duration: 1/2/4/8/16. Dot: .. Sharp: #. Flat: b. Rest: -")

    args = parser.parse_args()

    if args.cmd != "scan" and not args.device:
        print(
            f"error: no device address configured.\n"
            f"  Set ${_ENV_VAR}, create {_CONF_FILE}, or use --device ADDR.",
            file=sys.stderr,
        )
        sys.exit(1)

    match args.cmd:
        case "help":
            run(cmd_help(args.device, args.timeout))
        case "ping":
            do_send(args, "PING")
        case "tilt":
            do_send(args, "GET_TILT")
        case "calibrate":
            if args.ref:
                if len(args.ref) != 3:
                    print("error: calibrate expects 0 or 3 floats (gx gy gz)", file=sys.stderr)
                    sys.exit(1)
                do_send(args, f"CALIBRATE {args.ref[0]} {args.ref[1]} {args.ref[2]}")
            else:
                do_send(args, "CALIBRATE")
        case "calibrate-reset":
            do_send(args, "CALIBRATE_RESET")
        case "status":
            do_send(args, "GET_STATUS")
        case "get-time":
            do_send(args, "GET_TIME")
        case "get-radec":
            do_send(args, "GET_RADEC")
        case "get-altaz":
            do_send(args, "GET_ALTAZ")
        case "get-msg":
            do_send(args, "GET_MSG")
        case "cancel-msg":
            do_send(args, "CANCEL_MSG")
        case "stop-stream":
            do_send(args, "STOP_STREAM")
        case "set-time":
            cmd = f"SET_TIME {args.time}"
            if args.tz:
                cmd += f" {args.tz}"
            do_send(args, cmd)
        case "set-time-now":
            latency = timedelta(seconds=args.offset)
            if args.utc:
                now = datetime.now(timezone.utc) + latency
            elif args.timezone:
                tz = _resolve_tz(args.timezone)
                now = datetime.now(tz) + latency
            else:
                now = datetime.now().astimezone() + latency
            # Embed the UTC offset in the ISO8601 string so device subtracts it correctly.
            # An optional label override follows the timestamp.
            ts = now.strftime("%Y-%m-%dT%H:%M:%S") + _fmt_offset(now.utcoffset())
            cmd = f"SET_TIME {ts}"
            if not args.utc and not args.timezone and not args.label:
                label = now.strftime("%Z")
            else:
                label = args.label
            if label:
                cmd += f" {label}"
            do_send(args, cmd)
        case "set-timezone":
            spec = args.spec
            cmd = f"SET_TIME_ZONE {spec}"
            if args.label:
                cmd += f" {args.label}"
            do_send(args, cmd)
        case "set-longitude":
            do_send(args, f"SET_LONGITUDE {args.degrees}")
        case "set-radec":
            do_send(args, f"SET_RADEC {args.ra} {args.dec}")
        case "set-altaz":
            do_send(args, f"SET_ALTAZ {args.alt} {args.az}")
        case "show-msg":
            dur = "INF" if args.duration.lower() == "inf" else args.duration
            do_send(args, f"SHOW_MSG {dur} {args.text}")
        case "show-msg-wait":
            dur = "INF" if args.duration.lower() == "inf" else args.duration
            do_send(args, f"SHOW_MSG_WAIT {dur} {args.buttons} {args.text}")
        case "night-mode":
            do_send(args, f"SET_NIGHT_MODE {args.state.upper()}")
        case "beep":
            cmd = "BEEP " + " ".join(args.notes) if args.notes else "BEEP"
            do_send(args, cmd)
        case "persist":
            do_send(args, "PERSIST")
        case "persist-read":
            do_send(args, "PERSIST READ")
        case "persist-clear":
            do_send(args, "PERSIST CLEAR")
        case "persist-restore":
            do_send(args, "PERSIST RESTORE")
        case "reboot":
            do_send(args, "REBOOT")
        case "listen":
            run(cmd_listen(args.device, stream_ms=args.stream))
        case "scan":
            run(cmd_scan())


if __name__ == "__main__":
    main()
